		self.canvas.create_text(WIDTH // 2, 335,
								text="A parkour race against gravity",
								fill="#c5d5ed", font=("Segoe UI", 17))
		self.canvas.create_text(WIDTH // 2, 410,
								text="Press SPACE or click to start",
								fill="#ffcb5c", font=("Segoe UI", 16, "bold"))
		self.canvas.create_text(WIDTH // 2, 465,
								text=f"<  LEVEL {self.selected_level}: {self.level_names[self.selected_level]}  >    Use LEFT / RIGHT arrows to choose",
