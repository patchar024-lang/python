	def respawn_at_checkpoint(self, reason="SPIKED!"):
		self.player["x"] = self.checkpoint + 10
		self.player["y"] = self.checkpoint_y - self.player["h"]
		self.player["vy"] = 0
		self.player["grounded"] = False
		self.death_notice_timer = 0.65
		self.death_animation_timer = 0.65
		self.laser_immunity_timer = 1.0
		self.respawn_immunity_timer = 0.8
		self.death_notice_text = reason

	def key_down(self, event):
		key = event.keysym.lower()
		if key == "t" and key not in self.keys:
			self.mouse_locked = not self.mouse_locked
			self.root.config(cursor="none" if self.mouse_locked else "")
		if key == "space" and key not in self.keys:
			self.start_or_jump()
		if key == "d" and key not in self.keys and self.started and not self.shop_open:
			self.player["vx"] = 18
		self.keys.add(key)
		if key == "r":
			self.reset()
			self.started = True
		if not self.started and key in ("left", "right"):
			self.selected_level += 1 if key == "right" else -1
			self.selected_level = max(1, min(5, self.selected_level))
		if key == "b":
			self.shop_open = not self.shop_open
		if (self.shop_open or not self.started) and key in ("1", "2", "3", "4"):
			self.shop_action(int(key) - 1)
		if (self.shop_open or not self.started) and key in ("5", "6"):
			self.accessory_action(int(key) - 5)

	def shop_action(self, avatar_index):
		avatar_key = list(self.avatars)[avatar_index]
		avatar_name, price, body_color, pants_color = self.avatars[avatar_key]
		if avatar_key in self.unlocked_avatars:
			self.selected_avatar = avatar_key
		elif self.total_coins >= price:
			self.total_coins -= price
			self.coins_collected = self.total_coins
			self.unlocked_avatars.add(avatar_key)
			self.selected_avatar = avatar_key
			self.reward_text = f"UNLOCKED: {avatar_name} AVATAR"
			self.reward_timer = 1.5

	def accessory_action(self, accessory_index):
		accessory_key = list(self.accessories)[accessory_index]
		accessory_name, price = self.accessories[accessory_key]
		if accessory_key in self.unlocked_accessories:
			if accessory_key in self.selected_accessories:
				self.selected_accessories.remove(accessory_key)
			else:
				self.selected_accessories.add(accessory_key)
		elif self.total_coins >= price:
			self.total_coins -= price
			self.coins_collected = self.total_coins
			self.unlocked_accessories.add(accessory_key)
			self.selected_accessories.add(accessory_key)
			self.reward_text = f"UNLOCKED: {accessory_name}"
			self.reward_timer = 1.5

	def key_up(self, event):
		self.keys.discard(event.keysym.lower())

	def go_home(self):
		self.started = False
		self.finished = False
		self.shop_open = False
		self.selected_level = self.current_level
		self.mouse_locked = False
		self.root.config(cursor="")
		self.reset()

	def start_or_jump(self, _event=None):
		if not self.started or self.finished:
			self.current_level = self.selected_level
			self.reset()
			self.started = True
		elif self.player["grounded"]:
			self.player["vy"] = -14
			self.player["grounded"] = False
			self.player["jumps"] = 1
			self.jump_notice_timer = 0.45
		elif "double_jump" in self.selected_accessories and self.player["jumps"] < 2:
			self.player["vy"] = -14
			self.player["jumps"] = 2
			self.jump_notice_timer = 0.45

	def mouse_down(self, event):
		self.mouse_down_state = True
		if self.finished:
			if self.current_level < 5 and 18 <= event.x <= 250 and 500 <= event.y <= 570:
				self.finish_action("next")
			elif 425 <= event.x <= 675 and 500 <= event.y <= 570:
				self.finish_action("replay")
			elif 850 <= event.x <= 1080 and 500 <= event.y <= 570:
				self.finish_action("home")
			return
		if self.started and WIDTH - 150 <= event.x <= WIDTH - 18 and 18 <= event.y <= 58:
			self.go_home()
			return
		self.handle_touch(event.x, event.y, True)

	def finish_action(self, action):
		if action == "next" and self.current_level < 5:
			self.current_level += 1
			self.selected_level = self.current_level
		elif action == "home":
			self.go_home()
			return
		self.reset()
		self.started = True

	def mouse_up(self, event):
		self.mouse_down_state = False
		self.handle_touch(event.x, event.y, False)

	def mouse_move(self, event):
		if self.mouse_locked:
			mouse_delta_y = event.y - self.last_mouse_y
			self.look_y = max(-170, min(120, self.look_y - mouse_delta_y))
			self.last_mouse_y = event.y
		elif self.mouse_down_state:
			self.handle_touch(event.x, event.y, True)

	def handle_touch(self, x, y, pressed):
		if not self.started or self.finished:
			if pressed:
				self.current_level = self.selected_level
				self.reset()
				self.started = True
			return
		controls = {"left": (60, 605, 140, 685), "right": (150, 605, 230, 685),
					"dash": (780, 605, 890, 685), "jump": (910, 575, 1060, 685)}
		hit = next((name for name, box in controls.items()
					if box[0] <= x <= box[2] and box[1] <= y <= box[3]), None)
		if pressed and hit:
			if hit == "jump":
				self.start_or_jump()
			elif hit == "dash":
				self.player["vx"] = 18 if self.player["vx"] >= 0 else -18
			else:
				self.touch_keys.add(hit)
		elif not pressed:
			self.touch_keys.difference_update(("left", "right"))

	def down(self, *names):
		return any(name in self.keys or name in self.touch_keys for name in names)

	def update(self, dt):
		if not self.started or self.finished or self.shop_open:
			return
		self.elapsed += dt
		self.jump_notice_timer = max(0.0, self.jump_notice_timer - dt)
		self.death_notice_timer = max(0.0, self.death_notice_timer - dt)
		self.death_animation_timer = max(0.0, self.death_animation_timer - dt)
		self.laser_immunity_timer = max(0.0, self.laser_immunity_timer - dt)
		self.respawn_immunity_timer = max(0.0, self.respawn_immunity_timer - dt)
		self.reward_timer = max(0.0, self.reward_timer - dt)
		self.reward_speed_timer = max(0.0, self.reward_speed_timer - dt)
		forward = self.down("w")
		backward = self.down("s", "down")
		move_right = self.down("d", "right")
		move_left = self.down("a", "left")
		if forward:
			self.player["vx"] += 1.0
		if backward:
			self.player["vx"] -= 1.0
		if move_right:
			self.player["vx"] += 1.0
		if move_left:
			self.player["vx"] -= 1.0
		if not forward and not backward and not move_right and not move_left:
			self.player["vx"] *= 0.82
		slide_combo = forward and self.down("c")
		if slide_combo and not self.slide_combo_active:
			self.slide_timer = 0.5
		self.slide_combo_active = slide_combo
		self.slide_timer = max(0.0, self.slide_timer - dt)
		limit = 16 if self.slide_timer > 0 else 10
		if self.reward_speed_timer > 0:
			limit += 3
		self.player["vx"] = max(-limit, min(limit, self.player["vx"]))
		if self.down("space") and self.player["grounded"]:
			self.start_or_jump()
		old_x = self.player["x"]
		old_bottom = self.player["y"] + self.player["h"]
		gravity = 0.38 if "gravity" in self.selected_accessories else 0.65
		self.player["vy"] = min(18, self.player["vy"] + gravity)
		self.player["x"] += self.player["vx"]
		self.player["y"] += self.player["vy"]
		self.player["grounded"] = False
		solid_blocks = self.platforms + [
			(trap_x, GROUND_Y - 60, trap_width, 60)
			for trap_x, trap_width in self.traps
		]
		for block_x, block_y, block_width, block_height in solid_blocks:
			overlaps_x = (self.player["x"] + self.player["w"] > block_x and
						  self.player["x"] < block_x + block_width)
			overlaps_y = (self.player["y"] + self.player["h"] > block_y and
						  self.player["y"] < block_y + block_height)
			if not overlaps_x or not overlaps_y:
				continue
			if old_x + self.player["w"] <= block_x and self.player["x"] + self.player["w"] > block_x:
				self.player["x"] = block_x - self.player["w"]
				self.player["vx"] = 0
			elif old_x >= block_x + block_width and self.player["x"] < block_x + block_width:
				self.player["x"] = block_x + block_width
				self.player["vx"] = 0
		for px, py, pw, ph in self.platforms:
			overlaps_x = self.player["x"] + self.player["w"] > px and self.player["x"] < px + pw
			falling_onto = self.player["vy"] >= 0 and old_bottom <= py <= self.player["y"] + self.player["h"]
			if overlaps_x and falling_onto:
				self.player["y"] = py - self.player["h"]
				self.player["vy"] = 0
				self.player["grounded"] = True
				self.player["jumps"] = 0
				break
		if self.player["grounded"]:
			for checkpoint_x, checkpoint_y in self.checkpoints:
				if checkpoint_x > self.checkpoint and self.player["x"] >= checkpoint_x:
					self.checkpoint = checkpoint_x
					self.checkpoint_y = checkpoint_y
		for hazard_start, hazard_end in self.hazards:
			on_hazard = (self.player["x"] + self.player["w"] > hazard_start and
						 self.player["x"] < hazard_end)
			if on_hazard and self.player["grounded"] and self.player["y"] + self.player["h"] >= GROUND_Y:
				self.respawn_at_checkpoint()
				break
		for trap_x, trap_width in self.traps:
			over_trap = (self.player["x"] + self.player["w"] > trap_x and
						 self.player["x"] < trap_x + trap_width)
			trap_top = GROUND_Y - 60
			if over_trap and self.player["grounded"] and self.player["y"] + self.player["h"] > trap_top:
				self.respawn_at_checkpoint()
				break
		for laser_x, laser_y, laser_radius in self.lasers:
			laser_hit = (self.laser_immunity_timer <= 0 and
						 self.player["x"] + self.player["w"] > laser_x - laser_radius and
						 self.player["x"] < laser_x + laser_radius and
						 self.player["y"] + self.player["h"] > laser_y - laser_radius and
						 self.player["y"] < laser_y)
			if laser_hit:
				self.respawn_at_checkpoint("LASER HIT!  RESPAWNING AT CHECKPOINT")
				break
		if self.player["y"] > HEIGHT + 50:
			self.respawn_at_checkpoint("SPIKED!  RESPAWNING AT CHECKPOINT")
		remaining_coins = []
		for coin_x, coin_y in self.coins:
			coin_collected = (self.player["x"] + self.player["w"] > coin_x - 12 and
							  self.player["x"] < coin_x + 12 and
							  self.player["y"] + self.player["h"] > coin_y - 12 and
							  self.player["y"] < coin_y + 12)
			if coin_collected:
				self.coins_collected += 1
				self.total_coins += 1
				if self.coins_collected % 5 == 0:
					self.reward_speed_timer = 2.5
					self.reward_timer = 1.2
					self.reward_text = f"REWARD UNLOCKED!  SPEED BOOST x{self.coins_collected // 5}"
			else:
				remaining_coins.append((coin_x, coin_y))
		self.coins = remaining_coins
		if self.player["x"] >= self.finish_x:
			self.finished = True
		target_camera = max(0, self.player["x"] - 280)
		self.camera_x += (target_camera - self.camera_x) * 0.12

