			self.canvas.create_line(x - 12, 275, x - 16, 325, fill=pants_color, width=9)
			self.canvas.create_line(x + 12, 275, x + 16, 325, fill=pants_color, width=9)
			self.canvas.create_text(x, 350, text=f"{avatar_index + 1}. {avatar_name}",
								fill="#ffffff", font=("Segoe UI", 12, "bold"))
			status = "EQUIPPED" if avatar_key == self.selected_avatar else "OWNED" if unlocked else f"{price} COINS"
			self.canvas.create_text(x, 375, text=status, fill="#57d6b5" if unlocked else "#ffcb5c",
								font=("Segoe UI", 10, "bold"))
		for accessory_index, accessory_key in enumerate(self.accessories):
			accessory_name, price = self.accessories[accessory_key]
			x = 390 + accessory_index * 320
			owned = accessory_key in self.unlocked_accessories
			equipped = accessory_key in self.selected_accessories
			self.canvas.create_rectangle(x - 135, 445, x + 135, 570,
									 fill="#315b67" if equipped else "#243957",
									 outline="#57d6b5" if equipped else "#526783", width=3)
			self.canvas.create_oval(x - 28, 470, x + 28, 526,
									 fill="#ffdf75", outline="#fff4bf", width=2)
			self.canvas.create_text(x, 498, text="JUMP" if accessory_key == "double_jump" else "LOW G",
								fill="#6b4326", font=("Segoe UI", 9, "bold"))
			self.canvas.create_text(x, 540, text=f"{accessory_index + 5}. {accessory_name}",
								fill="#ffffff", font=("Segoe UI", 11, "bold"))
			status = "EQUIPPED" if equipped else "OWNED" if owned else f"{price} COINS"
			self.canvas.create_text(x, 560, text=status,
								fill="#57d6b5" if owned else "#ffcb5c",
								font=("Segoe UI", 10, "bold"))
		self.canvas.create_text(WIDTH // 2, 615,
							text="1-4: avatars    5-6: buy/equip accessories",
							fill="#c5d5ed", font=("Segoe UI", 13))

