			self.canvas.create_rectangle(0, 455, WIDTH, HEIGHT, fill="#3d2931", outline="")
		elif theme_level == 3:
			self.canvas.create_rectangle(0, 0, WIDTH, HEIGHT, fill="#111b2d", outline="")
			self.canvas.create_rectangle(0, 380, WIDTH, HEIGHT, fill="#17233a", outline="")
			for building_x, building_width, building_height in [(45, 100, 190), (210, 135, 260),
													  (420, 120, 220), (650, 150, 285), (875, 110, 210)]:
				x = building_x - (self.camera_x * 0.2 % 100)
				self.canvas.create_rectangle(x, 380 - building_height, x + building_width, 380,
													 fill="#263b59", outline="#4e7392", width=2)
				for window_y in range(400 - building_height, 365, 32):
					for window_x in range(int(x + 15), int(x + building_width - 10), 28):
						self.canvas.create_rectangle(window_x, window_y, window_x + 8, window_y + 12,
													 fill="#f4c96b", outline="")
			self.canvas.create_line(0, 420, WIDTH, 420, fill="#57d6b5", width=2)
		elif theme_level == 4:
			self.canvas.create_rectangle(0, 0, WIDTH, HEIGHT, fill="#a8d7e8", outline="")
			self.canvas.create_rectangle(0, 330, WIDTH, HEIGHT, fill="#5e9db5", outline="")
			self.canvas.create_polygon(0, 0, 180, 0, 245, 430, 0, 430,
									 fill="#d8f4fa", outline="#ffffff", width=3)
			self.canvas.create_polygon(WIDTH, 0, 920, 0, 855, 430, WIDTH, 430,
									 fill="#c4eaf2", outline="#ffffff", width=3)
			for ice_x in range(80, WIDTH, 160):
				self.canvas.create_line(ice_x, 90, ice_x + 30, 330,
									fill="#eaffff", width=4)
			self.canvas.create_rectangle(0, 450, WIDTH, HEIGHT, fill="#346b83", outline="")
		else:
			self.canvas.create_rectangle(0, 0, WIDTH, HEIGHT, fill="#080b20", outline="")
			self.canvas.create_rectangle(0, 390, WIDTH, HEIGHT, fill="#141840", outline="")
			for star_x, star_y in [(70, 110), (180, 215), (310, 80), (480, 150),
									  (625, 95), (760, 240), (900, 125), (1020, 70)]:
				self.canvas.create_oval(star_x, star_y, star_x + 4, star_y + 4,
										fill="#d9c8ff", outline="")
			self.canvas.create_oval(715, 115, 820, 220, fill="#bb8cff", outline="")
			self.canvas.create_oval(735, 135, 820, 220, fill="#080b20", outline="")
			for ring_y in (285, 325, 365):
				self.canvas.create_line(0, ring_y, WIDTH, ring_y,
									fill="#4c4aa0", width=2)

	def draw_world(self):
		self.canvas.delete("all")
		self.draw_background()
		for hx, end in self.hazards:
			x = hx - self.camera_x
			self.canvas.create_rectangle(x, GROUND_Y, end - self.camera_x, HEIGHT,
									 fill="#d64b5d", outline="")
			for spike in range(int(hx), int(end), 24):
				sx = spike - self.camera_x
				self.canvas.create_polygon(sx, GROUND_Y, sx + 12, GROUND_Y - 18,
									   sx + 24, GROUND_Y, fill="#ff7180", outline="")
		for px, py, pw, ph in self.platforms:
			x = px - self.camera_x
			if x + pw < 0 or x > WIDTH:
				continue
			self.canvas.create_rectangle(x, py, x + pw, py + ph,
									 fill="#3c527b", outline="#8ca9d8", width=2)
			self.canvas.create_rectangle(x, py, x + pw, py + 5, fill="#57d6b5", outline="")
		for trap_x, trap_width in self.traps:
			x = trap_x - self.camera_x
			if x + trap_width < 0 or x > WIDTH:
				continue
			self.canvas.create_rectangle(x, GROUND_Y - 60, x + trap_width, GROUND_Y,
									 fill="#9b4d32", outline="#e88d4f", width=2)
			for spike_offset in (-16, 0, 16):
				spike = x + trap_width / 2 + spike_offset
				self.canvas.create_polygon(spike - 9, GROUND_Y - 60, spike,
									   GROUND_Y - 82, spike + 9, GROUND_Y - 60,
									   fill="#f5f3ce", outline="")
		for laser_x, laser_y, laser_radius in self.lasers:
			x = laser_x - self.camera_x
			if x + laser_radius < 0 or x - laser_radius > WIDTH:
				continue
			self.canvas.create_arc(x - laser_radius, laser_y - laser_radius,
								   x + laser_radius, laser_y + laser_radius,
								   start=0, extent=180, style=tk.PIESLICE,
								   fill="#e51f3f", outline="#ff7180", width=2)
		for coin_x, coin_y in self.coins:
			x = coin_x - self.camera_x
			if -20 <= x <= WIDTH + 20:
				self.canvas.create_oval(x - 11, coin_y - 11, x + 11, coin_y + 11,
									fill="#f5b942", outline="#ffe59a", width=2)
				self.canvas.create_oval(x - 4, coin_y - 8, x + 1, coin_y - 2,
									fill="#fff4bf", outline="")
		for checkpoint_x, checkpoint_y in self.checkpoints:
			x = checkpoint_x - self.camera_x + 8
			if -30 <= x <= WIDTH + 30:
				self.canvas.create_line(x, checkpoint_y, x, checkpoint_y - 62,
									 fill="#f5f3ce", width=4)
				self.canvas.create_polygon(x, checkpoint_y - 60, x + 42,
									 checkpoint_y - 47, x, checkpoint_y - 34,
									 fill="#57d6b5" if checkpoint_x <= self.checkpoint else "#526783",
									 outline="")
		flag_x = self.finish_x - self.camera_x
		self.canvas.create_line(flag_x, 600, flag_x, 405, fill="#f5f3ce", width=5)
		self.canvas.create_polygon(flag_x, 410, flag_x + 95, 440, flag_x, 470,
								   fill="#ffcb5c", outline="")
		self.draw_player()
		self.canvas.create_rectangle(WIDTH - 150, 18, WIDTH - 18, 58, fill="#284264",
								 outline="#8ca9d8", width=2)
		self.canvas.create_text(WIDTH - 84, 38, text="HOME",
								fill="#ffffff", font=("Segoe UI", 12, "bold"))
		if self.death_notice_timer > 0:
			self.canvas.create_text(WIDTH // 2, 130, text=self.death_notice_text,
								fill="#ff7180", font=("Segoe UI", 20, "bold"))
		if self.jump_notice_timer > 0:
			self.canvas.create_text(WIDTH // 2, 130, text="JUMP!",
								fill="#ffcb5c", font=("Segoe UI", 28, "bold"))

	def draw_player(self):
		px = self.player["x"] - self.camera_x + 15
		py = self.player["y"]
		avatar_name, avatar_price, body_color, pants_color = self.avatars[self.selected_avatar]
		if self.death_animation_timer > 0:
			body_y = py + 34
			self.canvas.create_oval(px - 23, body_y - 10, px - 3, body_y + 10,
								fill="#f2b28d", outline="#412e3b", width=2)
			self.canvas.create_line(px - 4, body_y, px + 28, body_y,
							fill=body_color, width=16)
			self.canvas.create_line(px + 8, body_y + 7, px - 8, body_y + 22,
							fill=pants_color, width=7)
			self.canvas.create_line(px + 20, body_y + 7, px + 36, body_y + 22,
							fill=pants_color, width=7)
			self.canvas.create_line(px + 2, body_y - 5, px - 12, body_y - 18,
							fill="#f2b28d", width=6)
			self.canvas.create_line(px + 28, body_y - 5, px + 42, body_y - 18,
							fill="#f2b28d", width=6)
			self.canvas.create_text(px + 8, body_y - 38, text="X",
							fill="#ff7180", font=("Segoe UI", 18, "bold"))
			return
		walking = self.player["grounded"] and abs(self.player["vx"]) > 0.3
		step = 6 if walking and int(self.elapsed * 10) % 2 == 0 else -6
		jumping = not self.player["grounded"]
		head_y = py + 8
		self.canvas.create_oval(px - 12, head_y - 12, px + 12, head_y + 12,
							fill="#f2b28d", outline="#412e3b", width=2)
		self.canvas.create_arc(px - 12, head_y - 13, px + 12, head_y + 5,
							start=0, extent=180, fill="#4b2f2b", outline="#2b2028", width=2)
		self.canvas.create_oval(px - 5, head_y - 2, px - 3, head_y,
							fill="#202437", outline="")
		self.canvas.create_oval(px + 4, head_y - 2, px + 6, head_y,
							fill="#202437", outline="")
		self.canvas.create_line(px, head_y + 12, px, head_y + 18,
							fill="#f2b28d", width=5)
		self.canvas.create_rectangle(px - 13, py + 18, px + 13, py + 39,
									fill=body_color, outline="#d9f1ff", width=2)
		if jumping:
			self.canvas.create_line(px - 11, py + 21, px - 25, py + 8,
								 fill="#f2b28d", width=6)
			self.canvas.create_line(px + 11, py + 21, px + 25, py + 8,
								 fill="#f2b28d", width=6)
		else:
			self.canvas.create_line(px - 10, py + 22, px - 18, py + 37 + step,
								 fill="#f2b28d", width=6)
			self.canvas.create_line(px + 10, py + 22, px + 18, py + 37 - step,
								 fill="#f2b28d", width=6)
		self.canvas.create_line(px - 7, py + 39, px - 8 + step, py + 55,
							 fill=pants_color, width=7)
		self.canvas.create_line(px + 7, py + 39, px + 8 - step, py + 55,
							 fill=pants_color, width=7)
		self.canvas.create_line(px - 13 + step, py + 55, px - 3 + step, py + 55,
							 fill="#f5f3ce", width=4)
		self.canvas.create_line(px + 3 - step, py + 55, px + 13 - step, py + 55,
							 fill="#f5f3ce", width=4)

	def draw_controls(self):
		buttons = [(100, 645, "<", "left"), (190, 645, ">", "right"),
				   (835, 645, "DASH", "dash"), (985, 630, "JUMP", "jump")]
		for cx, cy, label, name in buttons:
			if name in ("left", "right"):
				self.canvas.create_oval(cx - 35, cy - 35, cx + 35, cy + 35,
										fill="#284264", outline="#8ca9d8", width=2)
			else:
				self.canvas.create_rectangle(cx - 52, cy - 30, cx + 52, cy + 30,
											 fill="#284264", outline="#8ca9d8", width=2)
			self.canvas.create_text(cx, cy, text=label, fill="#ffffff",
									font=("Segoe UI", 12, "bold"))

	def draw_hud(self):
		self.canvas.create_text(28, 26, anchor="w", text="SPLIT SECOND",
								fill="#ffffff", font=("Segoe UI", 20, "bold"))
		self.canvas.create_text(28, 55, anchor="w",
								text=f"LEVEL {self.current_level}: {self.level_names[self.current_level]}   TIME {self.elapsed:05.1f}   CHECKPOINT {int(self.checkpoint)}   COINS {self.total_coins}",
								fill="#9bb7d9", font=("Segoe UI", 11, "bold"))
		self.canvas.create_text(WIDTH - 28, 28, anchor="e",
								text="W forward   S back   A left   D right + dash   SPACE jump   W+C slide   T mouse lock",
								fill="#9bb7d9", font=("Segoe UI", 10))
		if self.player["grounded"]:
			self.canvas.create_text(WIDTH // 2, 70, text="SPACE  TO  JUMP",
								fill="#ffffff", font=("Segoe UI", 13, "bold"))
		if self.reward_timer > 0:
			self.canvas.create_text(WIDTH // 2, 160, text=self.reward_text,
								fill="#ffdf75", font=("Segoe UI", 22, "bold"))

