			self.canvas.create_text(x, 642, text=status, fill="#ffdf75", font=("Segoe UI", 9))

	def draw(self):
		if not self.started:
			self.draw_welcome()
			return
		self.draw_world()
		self.draw_hud()
		self.draw_controls()
		if self.shop_open:
			self.draw_shop()
		if self.finished:
			self.canvas.create_rectangle(180, 175, 920, 590, fill="#182641",
										 outline="#ffcb5c", width=3)
			self.canvas.create_text(WIDTH // 2, 235, text="COURSE CLEARED",
									fill="#ffcb5c", font=("Segoe UI", 30, "bold"))
			self.canvas.create_text(WIDTH // 2, 285,
									text=f"Time: {self.elapsed:.1f} seconds",
									fill="#ffffff", font=("Segoe UI", 18))
			if self.current_level < 5:
				self.canvas.create_rectangle(18, 500, 250, 570, fill="#315b67",
										 outline="#57d6b5", width=2)
				self.canvas.create_text(134, 535, text="NEXT LEVEL",
									fill="#ffffff", font=("Segoe UI", 13, "bold"))
			self.canvas.create_text(134, 557,
									text=self.level_names[self.current_level + 1],
									fill="#9bb7d9", font=("Segoe UI", 9))
			self.canvas.create_rectangle(425, 500, 675, 570, fill="#315b67",
									 outline="#ffcb5c", width=3)
			self.canvas.create_text(550, 535, text="PLAY AGAIN",
									fill="#ffffff", font=("Segoe UI", 13, "bold"))
			self.canvas.create_rectangle(850, 500, 1080, 570, fill="#315b67",
									 outline="#8ca9d8", width=2)
			self.canvas.create_text(965, 535, text="HOME",
									fill="#ffffff", font=("Segoe UI", 13, "bold"))

	def loop(self):
		now = self.root.tk.call("clock", "milliseconds") / 1000
		dt = min(0.04, now - self.last_time) if self.last_time else 0.016
		self.last_time = now
		self.update(dt)
		self.draw()
		self.root.after(16, self.loop)


if __name__ == "__main__":
	SplitSecond().root.mainloop()
