			self.canvas.create_oval(x - 12, 565, x + 12, 589, fill="#f2b28d", outline="")
			self.canvas.create_rectangle(x - 13, 588, x + 13, 612, fill=body_color, outline="")
			self.canvas.create_text(x, 625, text=f"{avatar_index + 1}. {avatar_name}",
